# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# New publishable key (preferred) or legacy anon JWT
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Local / production app URL
NEXT_PUBLIC_SITE_URL=https://finance-app-nine-blush.vercel.app

# Postgres — use Transaction pooler (port 6543) on Vercel
# postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Resend (lembretes de vencimento — opcional)
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=Finora <onboarding@resend.dev>

# Protege o cron /api/cron/due-reminders (Vercel Cron envia Authorization: Bearer …)
CRON_SECRET=gere-um-segredo-longo
