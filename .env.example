# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# New publishable key (preferred) or legacy anon JWT
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Local / production app URL
NEXT_PUBLIC_SITE_URL=https://finance-app-nine-blush.vercel.app

# Postgres — use Transaction pooler (port 6543) on Vercel
# postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Resend (lembretes de vencimento — opcional)
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=Te Organiza <onboarding@resend.dev>

# SAC — e-mail que recebe dúvidas escaladas do chat
SUPPORT_INBOX_EMAIL=voce@email.com

# Protege o cron /api/cron/due-reminders (Vercel Cron envia Authorization: Bearer …)
CRON_SECRET=gere-um-segredo-longo

# Mercado Pago — assinaturas Pro (checkout + webhook)
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxx
# Opcional: valida webhook via ?secret= ou header x-webhook-secret
MERCADOPAGO_WEBHOOK_SECRET=
# Opcional: IDs de planos no MP (senão usa auto_recurring inline)
MERCADOPAGO_PREAPPROVAL_PLAN_ID_MONTHLY=
MERCADOPAGO_PREAPPROVAL_PLAN_ID_ANNUAL=
