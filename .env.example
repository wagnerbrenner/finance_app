# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Site URL (OAuth redirect). Use http://localhost:3000 in local.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Postgres connection string (Supabase → Settings → Database)
# Prefer the pooled connection (port 6543) with ?pgbouncer=true for serverless.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
